KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8000/auth/social/kakao/callback

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/social/google/callback

# Optional for production/custom domains
# YEONGJU_PUBLIC_BASE_URL=https://your-domain.example

# Optional only when frontend is served on a different origin
# YEONGJU_FRONTEND_BASE_URL=http://127.0.0.1:5500
